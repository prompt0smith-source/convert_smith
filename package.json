{
  "name": "convert-smith",
  "version": "0.1.4",
  "description": "Local-first Electron file conversion app that creates genuinely usable output formats.",
  "main": "dist-electron/main/main.js",
  "type": "module",
  "private": true,
  "author": "JINKYU YOO",
  "copyright": "Copyright © 2026 JINKYU YOO",
  "scripts": {
    "start": "npm run build && node scripts/start-electron.mjs",
    "dev": "npm run electron:dev",
    "renderer:dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build && tsc -p tsconfig.electron.json && node scripts/copy-preload-cjs.mjs",
    "electron:dev": "concurrently -k \"npm run renderer:dev\" \"wait-on tcp:5173 && tsc -p tsconfig.electron.json --watch\" \"wait-on tcp:5173 file:dist-electron/main/main.js && node scripts/copy-preload-cjs.mjs && node scripts/start-electron-dev.mjs\"",
    "electron:build": "npm run build && electron-builder",
    "dist": "npm run electron:build",
    "smoke": "node scripts/smoke-test.mjs"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.80",
    "docx": "^9.5.1",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "heic-convert": "^2.1.0",
    "lucide-react": "^0.468.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.4.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.convertsmith.app",
    "productName": "Convert Smith",
    "copyright": "Copyright © 2026 JINKYU YOO",
    "icon": "icon",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "THIRD_PARTY_NOTICES.md",
      "legal/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build",
        "to": "build"
      },
      {
        "from": "THIRD_PARTY_NOTICES.md",
        "to": "THIRD_PARTY_NOTICES.md"
      },
      {
        "from": "legal",
        "to": "legal"
      }
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/ffprobe-static/**",
      "node_modules/pdfjs-dist/**",
      "node_modules/sharp/**",
      "node_modules/@img/**",
      "node_modules/@napi-rs/**"
    ],
    "win": {
      "target": "nsis",
      "artifactName": "Convert Smith Setup ${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Convert Smith",
      "license": "legal/INSTALLER_EULA.txt"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
